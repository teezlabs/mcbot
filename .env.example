# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Discord channel ID where MC events are posted and Discord messages are read
DISCORD_CHANNEL_ID=your_channel_id_here

# Webhook URL for the same channel (Settings → Integrations → Webhooks → New Webhook)
DISCORD_WEBHOOK_URL=your_webhook_url_here

# Path to latest.log on the HOST machine (mounted read-only into the container)
MC_LOG_HOST_PATH=/path/to/your/minecraft/server/logs/latest.log

# RCON settings (must be enabled in server.properties)
RCON_HOST=host-gateway
RCON_PORT=25575
RCON_PASSWORD=your_rcon_password
