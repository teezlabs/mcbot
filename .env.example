# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Discord channel ID where MC events are posted and Discord messages are read
DISCORD_CHANNEL_ID=your_channel_id_here

# Webhook URL for the same channel (Settings → Integrations → Webhooks → New Webhook)
DISCORD_WEBHOOK_URL=your_webhook_url_here

# Path to the logs DIRECTORY on the HOST machine (mounted read-only into the container).
# Mount the directory, not latest.log directly — bind-mounting the file pins the inode and
# breaks log rotation, so the bot will silently stop seeing new lines after the first rotation.
MC_LOG_HOST_DIR=/path/to/your/minecraft/server/logs

# RCON settings (must be enabled in server.properties)
RCON_HOST=host-gateway
RCON_PORT=25575
RCON_PASSWORD=your_rcon_password

# Modpack update checker (optional)
# Get a free API key at https://console.curseforge.com
# Find the project ID on the modpack's CurseForge page (About Project → Project ID)
CURSEFORGE_API_KEY=your_curseforge_api_key
CURSEFORGE_PROJECT_ID=your_project_id
# How often to check for updates in milliseconds (default: 1 hour)
# PACK_UPDATE_INTERVAL_MS=3600000
